{
  "name": "@atlasent/verify",
  "version": "1.0.0",
  "description": "AtlaSent offline audit-bundle verifier — zero-dependency Node CLI and library",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "atlasent-verify": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "atlasent",
    "verify",
    "audit",
    "authorization",
    "offline-verification"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AtlaSent-Systems-Inc/atlasent-sdk.git",
    "directory": "typescript/packages/verify"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "@vitest/coverage-v8": "^4.1.5",
    "tsup": "^8.0.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
