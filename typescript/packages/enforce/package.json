{
  "name": "@atlasent/enforce",
  "version": "0.1.0-alpha.0",
  "description": "AtlaSent Enforce Pack — non-bypassable execution wrapper around the v1 SDK. Forces verify-permit on every gated action; fails closed.",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run typecheck && npm test && npm run build",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "atlasent",
    "enforce",
    "authorization",
    "verify-permit",
    "fail-closed"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AtlaSent-Systems-Inc/atlasent-sdk.git",
    "directory": "typescript/packages/enforce"
  },
  "publishConfig": {
    "access": "public",
    "tag": "alpha"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.0.2",
    "typescript": "^5.9.3",
    "vitest": "^3.0.0",
    "@vitest/coverage-v8": "^3.0.0"
  }
}
