{
  "name": "@atlasent/mcp",
  "version": "1.5.1",
  "description": "AtlaSent MCP server — expose AtlaSent authorization as Claude tools",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "atlasent-mcp": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "atlasent",
    "mcp",
    "model-context-protocol",
    "authorization",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AtlaSent-Systems-Inc/atlasent-sdk.git",
    "directory": "typescript/packages/mcp"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "peerDependencies": {
    "@atlasent/sdk": "^1.5.0"
  },
  "devDependencies": {
    "@atlasent/sdk": "file:../../",
    "@types/node": "^25.6.0",
    "tsup": "^8.0.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
