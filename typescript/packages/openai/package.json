{
  "name": "@atlasent/openai-middleware",
  "version": "1.5.1",
  "description": "AtlaSent authorization middleware for the OpenAI SDK — authorize every tool call before execution",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["atlasent", "openai", "authorization", "middleware", "agent-security"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AtlaSent-Systems-Inc/atlasent-sdk.git",
    "directory": "typescript/packages/openai"
  },
  "peerDependencies": {
    "openai": ">=4.0.0",
    "@atlasent/sdk": "^1.5.0"
  },
  "devDependencies": {
    "openai": "^6.35.0",
    "@atlasent/sdk": "file:../../",
    "@types/node": "^25.6.0",
    "tsup": "^8.0.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
