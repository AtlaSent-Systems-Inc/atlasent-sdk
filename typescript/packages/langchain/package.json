{
  "name": "@atlasent/langchain",
  "version": "1.6.0",
  "description": "AtlaSent authorization wrapper for LangChain tools — authorize every tool call before execution",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": { "types": "./dist/index.d.ts", "default": "./dist/index.js" },
      "require": { "types": "./dist/index.d.cts", "default": "./dist/index.cjs" }
    },
    "./package.json": "./package.json"
  },
  "files": ["dist", "README.md", "LICENSE"],
  "engines": { "node": ">=20" },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run clean && npm run typecheck && npm test && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["atlasent", "langchain", "authorization", "middleware", "agent-security"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AtlaSent-Systems-Inc/atlasent-sdk.git",
    "directory": "typescript/packages/langchain"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@atlasent/sdk": "^1.5.0 || ^2.0.0"
  },
  "devDependencies": {
    "@atlasent/sdk": "file:../../",
    "@types/node": "^25.6.0",
    "tsup": "^8.0.2",
    "typescript": "^5.9.3",
    "vitest": "^4.1.5"
  }
}
