{
  "name": "@atlasent/sdk",
  "version": "1.1.0",
  "description": "AtlaSent TypeScript SDK — policy evaluation, permit management, and governance",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts"
    },
    "./testing": {
      "import": "./dist/testing/index.mjs",
      "require": "./dist/testing/index.js",
      "types": "./dist/testing/index.d.ts"
    }
  },
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@atlasent/types": "^2.0.0"
  },
  "devDependencies": {
    "typescript": "^5.4.5",
    "tsup": "^8.0.2",
    "vitest": "^1.5.0",
    "@types/node": "^20.12.7"
  },
  "peerDependencies": {
    "@opentelemetry/api": "^1.8.0"
  },
  "peerDependenciesMeta": {
    "@opentelemetry/api": { "optional": true }
  },
  "files": ["dist"],
  "license": "MIT"
}
