{
  "name": "@atlasent/verify",
  "version": "0.1.0-rc.0",
  "description": "Offline verifier for AtlaSent signed audit-export bundles",
  "license": "Apache-2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "tsup",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "atlasent",
    "audit",
    "verify",
    "ed25519",
    "compliance",
    "21cfr",
    "gxp"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AtlaSent-Systems-Inc/atlasent-sdk.git",
    "directory": "verify/typescript"
  },
  "homepage": "https://github.com/AtlaSent-Systems-Inc/atlasent-sdk/tree/main/verify/typescript#readme",
  "bugs": {
    "url": "https://github.com/AtlaSent-Systems-Inc/atlasent-sdk/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@atlasent/sdk": "^1.4.0"
  },
  "devDependencies": {
    "@atlasent/sdk": "^1.4.0",
    "@types/node": "^20.12.7",
    "tsup": "^8.0.2",
    "typescript": "^5.4.5",
    "vitest": "^1.5.0"
  }
}
