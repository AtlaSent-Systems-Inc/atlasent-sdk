# AtlaSent SDK configuration
#
# Copy this file to `.env` and fill in your real keys, then load it
# (e.g. with `source .env` or python-dotenv) before running your code.
#
# Get your keys at https://atlasent.io → Settings → API Keys

# Required — server-side / live API key
ATLASENT_API_KEY=ask_live_your_key_here

# Optional — anonymous / public key for client-side contexts
ATLASENT_ANON_KEY=ask_anon_your_key_here
