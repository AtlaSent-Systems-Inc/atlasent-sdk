{
  "id": "SIM-07",
  "title": "Tampered permit token",
  "description": "evaluate returns allow with a permit. The test harness flips one byte of the permit token (indicated by tamper_token: true) before passing it to verifyPermit. verifyPermit returns 400 with reason_code permit_tampered. execute must not run.",
  "enforce_config": {
    "bindings": {
      "org_id": "org_test",
      "actor_id": "actor_test",
      "action_type": "deploy"
    },
    "fail_closed": true
  },
  "clock": { "now_iso": "2026-04-29T12:00:00Z" },
  "request": { "commit": "abc123", "environment": "production" },
  "mocks": {
    "evaluate": {
      "type": "response",
      "decision": "allow",
      "permit": {
        "token": "pt_valid_sig_aabbcc",
        "expires_at": "2026-04-29T13:00:00Z"
      },
      "reason_code": null
    },
    "verify_permit": {
      "type": "http_error",
      "http_status": 400,
      "reason_code": "permit_tampered",
      "tamper_token": true
    }
  },
  "expected": {
    "decision": "deny",
    "reason_code": "permit_tampered",
    "execute_called": false,
    "verify_permit_called": true
  }
}
