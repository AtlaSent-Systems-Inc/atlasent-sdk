      "decision": "allow",
      "permit": {
        "token": "pt_valid_aabbcc",
        "expires_at": "2026-04-29T13:00:00Z"
      },
      "reason_code": null
    },
    "verify_permit": {
      "type": "http_error",
      "http_status": 503,
      "reason_code": null
