[
  {
    "id": "allow-basic",
    "description": "Simple allow — no context required",
    "request": { "agent": "test-agent", "action": "read" },
    "mock_response": { "decision": "ALLOW", "permitted": true, "permit_token": "pt_test_allow" },
    "expect": { "decision": "ALLOW", "permitted": true }
  },
  {
    "id": "deny-basic",
    "description": "Simple deny",
    "request": { "agent": "test-agent", "action": "delete" },
    "mock_response": { "decision": "DENY", "permitted": false, "deny_code": "ACTION_NOT_PERMITTED", "reason": "Delete not allowed" },
    "expect": { "decision": "DENY", "permitted": false, "deny_code": "ACTION_NOT_PERMITTED" },
    "expect_exception": "AtlaSentDeniedError"
  },
  {
    "id": "hold-basic",
    "description": "Hold for manual review",
    "request": { "agent": "test-agent", "action": "deploy", "context": { "environment": "production" } },
    "mock_response": { "decision": "HOLD", "permitted": false, "reason": "Requires human review", "hold_id": "hold_abc" },
    "expect": { "decision": "HOLD", "permitted": false },
    "expect_exception": "AtlaSentHoldError"
  },
  {
    "id": "escalate-basic",
    "description": "Escalate to higher authority",
    "request": { "agent": "test-agent", "action": "data.export", "context": { "record_count": 50000 } },
    "mock_response": { "decision": "ESCALATE", "permitted": false, "reason": "Requires escalation" },
    "expect": { "decision": "ESCALATE", "permitted": false }
  },
  {
    "id": "allow-with-context",
    "description": "Allow with full context",
    "request": {
      "agent": "github:deploy-bot",
      "action": "production.deploy",
      "context": { "environment": "prod", "approvals": 2, "change_window": true }
    },
    "mock_response": { "decision": "ALLOW", "permitted": true, "permit_token": "pt_test_deploy" },
    "expect": { "decision": "ALLOW", "permitted": true }
  },
  {
    "id": "allow-fail-open",
    "description": "Fail-open mode allows when no rule matches",
    "request": { "agent": "test-agent", "action": "unknown", "fail_mode": "open" },
    "mock_response": { "decision": "ALLOW", "permitted": true, "permit_token": "pt_failopen" },
    "expect": { "decision": "ALLOW", "permitted": true }
  },
  {
    "id": "http-401",
    "description": "Invalid API key → AtlaSentAPIError",
    "request": { "agent": "test-agent", "action": "read" },
    "mock_status": 401,
    "mock_response": { "error": "Unauthorized" },
    "expect_exception": "AtlaSentAPIError"
  }
]
