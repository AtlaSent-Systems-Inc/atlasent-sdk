{
  "description": "Arrays preserve input order; their contents canonicalize.",
  "vectors": [
    {
      "name": "simple_array",
      "input": [
        3,
        1,
        2
      ],
      "expected": "[3,1,2]"
    },
    {
      "name": "array_of_objects",
      "input": [
        {
          "b": 1
        },
        {
          "a": 2
        },
        {
          "c": 3
        }
      ],
      "expected": "[{\"b\":1},{\"a\":2},{\"c\":3}]"
    },
    {
      "name": "nested_arrays",
      "input": [
        [
          1,
          2
        ],
        [
          3,
          4
        ]
      ],
      "expected": "[[1,2],[3,4]]"
    },
    {
      "name": "mixed",
      "input": [
        1,
        "two",
        {
          "three": 3
        },
        [
          4,
          5
        ],
        null
      ],
      "expected": "[1,\"two\",{\"three\":3},[4,5],null]"
    }
  ]
}
