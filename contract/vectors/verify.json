          "environment": "production",
          "patient_id": "PT-001",
          "change_reason": "Correct date-of-birth"
        }
      },
      "api_key": "ask_live_test_key",
      "wire_request": {
        "permit_token": "dec_ctx_allow_002",
        "action_type": "modify_patient_record",
        "actor_id": "clinical-data-agent"
      },
      "wire_response": {
        "valid": true,
        "outcome": "allow",
        "decision": "allow",
        "reason": "Permit verified and consumed"
      },
      "sdk_output": {
        "verified": true,
        "outcome": "allow",
        "permit_hash": "",
        "timestamp": ""
      }
    },
