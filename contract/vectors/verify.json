{
  "description": "Round-trip vectors for POST /v1-verify-permit. Wire shape is canonical (handler.ts) — only `permit_token` is required server-side; `action_type` and `actor_id` are optional cross-checks. SDKs accept legacy `wire_response` shapes with `verified` for backward-compat.",
  "vectors": [
    {
      "name": "verify_permit_happy",
      "description": "Happy-path verification of a previously issued permit.",
      "sdk_input": {
        "permit_id": "dec_ctx_allow_002",
