[
  {
    "id": "verify-valid",
    "description": "Valid permit token verifies successfully",
    "request": { "permit_token": "pt_test_valid" },
    "mock_response": { "valid": true, "outcome": "verified" },
    "expect": { "valid": true, "outcome": "verified" }
  },
  {
    "id": "verify-expired",
    "description": "Expired permit token returns valid=false",
    "request": { "permit_token": "pt_test_expired" },
    "mock_response": { "valid": false, "outcome": "expired", "reason": "Permit token has expired" },
    "expect": { "valid": false, "outcome": "expired" }
  },
  {
    "id": "verify-invalid",
    "description": "Malformed or tampered token returns valid=false",
    "request": { "permit_token": "pt_bad_token" },
    "mock_response": { "valid": false, "outcome": "invalid" },
    "expect": { "valid": false }
  },
  {
    "id": "verify-replay",
    "description": "Replayed (already-used) token returns valid=false",
    "request": { "permit_token": "pt_test_used" },
    "mock_response": { "valid": false, "outcome": "invalid", "reason": "Permit already consumed" },
    "expect": { "valid": false }
  }
]
