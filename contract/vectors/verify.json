      "description": "valid=false is NOT a transport error; SDKs MUST return the body, not throw. The verify_error_code surfaces the specific reason (PERMIT_EXPIRED here).",
      "sdk_input": { "permit_id": "dec_expired" },
      "api_key": "ask_live_test_key",
