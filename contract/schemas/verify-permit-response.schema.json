{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://atlasent.io/contract/v1/verify-permit-response.schema.json",
  "title": "VerifyPermitResponse",
  "description": "Value-based response from POST /v1-verify-permit. The server returns this envelope on every code path (including 400/401/403/429). Callers MUST inspect `valid` and `outcome` -- HTTP status is not authoritative.",
  "type": "object",
  "additionalProperties": true,
  "required": ["valid", "outcome", "reason"],
  "properties": {
    "valid": {
      "type": "boolean",
      "description": "true iff the permit was verified and consumed by this call."
    },
    "outcome": {
      "type": "string",
      "enum": ["allow", "deny"],
      "description": "Normalised outcome used by enforcement callers."
    },
    "decision": {
      "type": "string",
      "enum": ["allow"],
      "description": "Present only when valid=true."
    },
    "verify_error_code": {
      "type": "string",
      "enum": [
        "MISSING_PERMIT",
        "PERMIT_NOT_FOUND",
        "PERMIT_NOT_ALLOWED",
        "PERMIT_EXPIRED",
        "PERMIT_REVOKED",
        "PERMIT_ALREADY_USED",
        "ACTOR_MISMATCH",
        "ACTION_TYPE_MISMATCH",
        "UNAUTHORIZED",
        "INVALID_API_KEY",
        "INSUFFICIENT_SCOPE",
        "RATE_LIMITED",
        "INTERNAL_ERROR"
      ],
      "description": "Machine-readable reason when valid=false."
    },
    "reason": {
      "type": "string",
      "description": "Human-readable explanation."
    }
  }
}
