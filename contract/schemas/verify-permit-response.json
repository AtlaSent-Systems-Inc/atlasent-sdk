{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "VerifyPermitResponse",
  "type": "object",
  "required": ["valid"],
  "properties": {
    "valid": {
      "type": "boolean",
      "description": "Whether the permit token is valid and unexpired"
    },
    "outcome": {
      "type": "string",
      "enum": ["verified", "expired", "invalid", "not_found", "error"],
      "description": "Machine-readable verification outcome"
    },
    "reason": {
      "type": "string",
      "description": "Human-readable explanation when valid is false"
    },
    "audit_id": {
      "type": "string",
      "description": "Server-side audit log ID"
    }
  },
  "additionalProperties": true
}
